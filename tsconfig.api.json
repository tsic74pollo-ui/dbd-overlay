{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.api.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "skipLibCheck": true,

    /* package.json has "type":"module", so Vercel's Node runtime resolves
       api/*.ts as native ESM at runtime — relative imports need an explicit
       .js extension (even though the source is .ts) or the function crashes
       at runtime with ERR_MODULE_NOT_FOUND. "bundler" mode doesn't enforce
       this and let a real production outage (FUNCTION_INVOCATION_FAILED)
       slip past local `npm run build`. nodenext matches Vercel for real. */
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["api"]
}
