# Ably (realtime transport). Get a key at https://ably.com/dashboard —
# ideally restrict its capability to publish/subscribe/presence only.
#
# No VITE_ prefix on purpose: this key stays server-only. It is read by
# api/ably-token.ts (Vercel) / the Vite dev middleware (local), which mint
# short-lived tokens scoped to this app's "dbd:*" channels for the browser.
# It must NEVER be renamed to VITE_ABLY_KEY — that would bundle it into
# client code and expose it to every visitor.
ABLY_API_KEY=your-ably-key-here
